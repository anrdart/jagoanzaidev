# ============================================
# Jagoan Zaidev - Environment Variables
# ============================================

# Neon Database URL
# Get this from your Neon dashboard: https://console.neon.tech/
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_URL=

# Public URL for client-side access (optional)
PUBLIC_NEON_DATABASE_URL=

# ============================================
# How to get Neon Database URL:
# ============================================
# 1. Go to https://console.neon.tech/
# 2. Create a new project or select existing
# 3. Go to Dashboard → Connection Details
# 4. Copy the "Connection string"
# 5. Paste it above after NEON_DATABASE_URL=

# ============================================
# Running SQL Schema:
# ============================================
# 1. Go to Neon Dashboard → SQL Editor
# 2. Open db/schema.sql file
# 3. Copy and paste the SQL content
# 4. Run the query to create tables
